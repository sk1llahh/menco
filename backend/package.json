{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "dev": "tsx watch -r tsconfig-paths/register src/index.ts",
    "build": "tsup src --clean --format cjs,esm --out-dir dist",
    "start": "node dist/index.js",
    "start:dev": "tsx -r tsconfig-paths/register src/index.ts",
    "prisma:generate": "dotenv -e ../.env -- npx prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "dotenv -e ../.env -- npx prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:deploy": "dotenv -e ../.env -- npx prisma migrate deploy --schema=prisma/schema.prisma",
    "prisma:studio": "dotenv -e ../.env -- npx prisma studio --schema=prisma/schema.prisma",
    "db:push": "dotenv -e ../.env -- npx prisma db push --schema=prisma/schema.prisma",
    "db:reset": "dotenv -e ../.env -- npx prisma db push --force-reset --schema=prisma/schema.prisma"
  },
  "keywords": [],
  "author": "Zhumabekov Adilkhan",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.14.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dayjs": "^1.11.12",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-handler": "^1.2.0",
    "helmet": "^7.1.0",
    "http-status": "^1.7.4",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "zod": "^4.0.17",
    "zod-openapi": "^5.4.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/debug": "^4.1.12",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.14.9",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "debug": "^4.3.6",
    "eslint": "^9.33.0",
    "eslint-plugin-node": "^11.1.0",
    "prisma": "^6.14.0",
    "tsconfig-paths": "^4.2.0",
    "tsup": "^8.2.4",
    "tsx": "^4.16.5",
    "typescript": "^5.5.2"
  }
}
