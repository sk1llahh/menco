{
  "compilerOptions": {
    "target": "ES2020",
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "allowImportingTsExtensions": false,
    "composite": true,
    "isolatedModules": true,
    "noImplicitAny": false
  }
}
